    "test:zhihu": "node scripts/test-zhihu-monotonicity.mjs",
    "test:domain": "node scripts/test-domain.mjs",
    "postinstall": "node scripts/copy-katex.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/arvin_123/math-function-map.git"
  },
